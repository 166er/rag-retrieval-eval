# =============================================================================
# Platzhalter-Konfiguration. Kopie als .env ablegen und Werte eintragen.
# GPU-Host = vLLM, Embeddings, Reranker. VM-HOST = n8n/Qdrant-VM.
# =============================================================================

# --- GPU-Host-Dienste (docker-compose.yml) ---
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXX
HF_CACHE_DIR=/home/USER/.cache/huggingface
MODELS_DIR=/home/USER/models

# --- Qdrant (docker-compose_qdrant.yml) ---
QDRANT_API_KEY=CHANGE_ME

# --- n8n + Postgres (docker-compose_n8n.yml) ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=n8n
SUBDOMAIN=n8n
DOMAIN_NAME=example.local
N8N_SECURE_COOKIE=false
N8N_ENCRYPTION_KEY=CHANGE_ME
GENERIC_TIMEZONE=Europe/Berlin

# --- Endpunkte aus Sicht der n8n-Workflows (via $env in den HTTP-Nodes) ---
RAG_VLLM_BASE=http://GPU-HOST:5678/v1
RAG_EMBED_BASE=http://GPU-HOST:8082
RAG_RERANK_BASE=http://GPU-HOST:8081

# Qdrant (läuft im selben Docker-Netz wie n8n -> Container-DNS-Name)
RAG_QDRANT_BASE=http://qdrant:6333
RAG_QDRANT_COLLECTION=CHANGE_ME
