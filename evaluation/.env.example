# Prototypen-Webhooks (n8n auf der VM)
P1_WEBHOOK_URL=http://VM-HOST:5678/webhook/advanced-rag
P2_WEBHOOK_URL=http://VM-HOST:5678/webhook/agentic-rag
# Judge (vLLM, OpenAI-kompatibel, GPU-Host)
JUDGE_BASE_URL=http://GPU-Host:8001/v1
JUDGE_MODEL=Qwen/Qwen3-32B
JUDGE_API_KEY=dummy
# Embeddings (BGE-M3 FastAPI, GPU-Host)
EMBED_BASE_URL=http://GPU-Host:8082
# Eingabedaten: synthetische Beispieldaten (die in der Arbeit verwendete
QUERIES_PATH=./sample_data/queries.jsonl
QRELS_PATH=./sample_data/qrels.txt
REFERENCE_ANSWERS_PATH=./sample_data/reference_answers.jsonl
# Ausgaben
RUNS_DIR=./runs
RESULTS_DIR=./results
# Enthaltungs-Formulierung (Negative Rejection)
ABSTAIN_PHRASE=Dazu liegen mir keine Informationen vor.
# Eval-Modul-Version
EVAL_MODULE_VERSION=1.0.0
